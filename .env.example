# ============================================
# MARKOPILOT V2 — Environment Variables
# ============================================
# Copy this file to each project's local env file
# Frontend: apps/web/.env.local
# Backend: apps/api/appsettings.Development.json (or environment)

# ── Frontend (apps/web/.env.local) ──────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID=
NEXT_PUBLIC_LEMON_SQUEEZY_STARTER_VARIANT_ID=
NEXT_PUBLIC_LEMON_SQUEEZY_GROWTH_VARIANT_ID=
NEXT_PUBLIC_LEMON_SQUEEZY_SCALE_VARIANT_ID=

# ── Backend (apps/api/ environment) ─────────────
# Supabase
Supabase__Url=
Supabase__ServiceRoleKey=
Supabase__JwtSecret=

# Redis (Upstash)
Redis__ConnectionString=

# AI (OpenRouter)
OpenRouter__ApiKey=

# Search
Serper__ApiKey=
Exa__ApiKey=

# Payments — Subscriptions (Lemon Squeezy)
LemonSqueezy__ApiKey=
LemonSqueezy__WebhookSigningSecret=
LemonSqueezy__StoreId=

# Payments — Marketplace (Flutterwave, scaffolded)
Flutterwave__SecretKey=
Flutterwave__WebhookHash=

# Encryption (AES-256)
Encryption__AesKey=               # 256-bit base64
Encryption__AesIv=                # 128-bit base64

# Social Platform OAuth
Twitter__ClientId=
Twitter__ClientSecret=
LinkedIn__ClientId=
LinkedIn__ClientSecret=
Instagram__AppId=
Instagram__AppSecret=
TikTok__ClientKey=
TikTok__ClientSecret=
