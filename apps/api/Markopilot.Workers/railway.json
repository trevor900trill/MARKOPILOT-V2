{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish Markopilot.Workers.csproj -c Release -o out_worker"
  },
  "deploy": {
    "startCommand": "dotnet out_worker/Markopilot.Workers.dll",
    "restartPolicyType": "ON_FAILURE"
  }
}
