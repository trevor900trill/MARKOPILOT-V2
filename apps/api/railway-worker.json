{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Markopilot.Workers/Dockerfile",
    "watchPatterns": ["apps/api/Markopilot.Workers/**", "apps/api/Markopilot.Core/**", "apps/api/Markopilot.Infrastructure/**", "apps/api/railway-worker.json"]
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE"
  }
}